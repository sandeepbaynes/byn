# Maintainer: Sandeep Baynes <https://github.com/sandeepbaynes/byn>
#
# Reserves `byn` on the AUR using the prebuilt binary (source stays private).
# After `make dist` + hosting, replace the SKIP checksums with the real ones
# from dist/byn-0.0.1.sha256, then push to ssh://aur@aur.archlinux.org/byn.git
# (run `makepkg --printsrcinfo > .SRCINFO` first).
pkgname=byn
pkgver=0.0.1
pkgrel=1
pkgdesc="Local-first secure secrets vault and credential manager"
arch=('x86_64' 'aarch64')
url="https://github.com/sandeepbaynes/byn"
license=('custom:BUSL-1.1')
source_x86_64=("byn-$pkgver-x86_64::https://github.com/sandeepbaynes/byn/releases/download/v$pkgver/byn-linux-amd64")
source_aarch64=("byn-$pkgver-aarch64::https://github.com/sandeepbaynes/byn/releases/download/v$pkgver/byn-linux-arm64")
sha256sums_x86_64=('SKIP')
sha256sums_aarch64=('SKIP')

package() {
  install -Dm755 "$srcdir/byn-$pkgver-$CARCH" "$pkgdir/usr/bin/byn"
}
